   "source": [
    "import pandas as pd\n",
    "\n",
    "data={\n",
    "    \"name\":[\"anwar\",\"habib\",\"rakib\"],\n",
    "    \"marks\":[50,75,35]\n",
    "}\n",
    "df=pd.DataFrame(data)\n",
    "\n",
    "def add_bonus(x):\n",
    "    return x+4\n",
    "\n",
    "df[\"marks\"]=df[\"marks\"].apply(add_bonus)\n",
    "print(df)\n"
   ]
  },
